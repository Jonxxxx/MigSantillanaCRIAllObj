+ Last(Fields!SUBTOTALCaption.Value, "DataSet_Result") + chr(177) 
+ Cstr(Sum(Fields!Sales_Invoice_Line_Amount.Value)) + chr(177) 
+ Last(Fields!txtIva.Value, "DataSet_Result") + chr(177) 
+ Cstr(Code.BlankZero(Sum(Fields!Amount_Including_VAT____Amount.Value))) + chr(177) 
+ Cstr(Sum(Fields!Amount____Line_Discount_Amount_.Value)) + chr(177) 
+ Cstr(Sum(Fields!Sales_Invoice_Line__Line_Discount_Amount_.Value)) + chr(177) 
+ Cstr(Sum(Fields!Sales_Invoice_Line_Amount.Value)) + chr(177) 
+ Cstr(Sum(Fields!Amount_Including_VAT____Amount.Value)) + chr(177) 
+ Cstr(Sum(Fields!Sales_Invoice_Line__Amount_Including_VAT_.Value)) + chr(177)
+ Cstr(First(Fields!Amount____Line_Discount_Amount_Format.Value))</Value>
                                  <Style>
                                    <FontFamily>times new roman</FontFamily>
                                    <FontSize>8pt</FontSize>
                                    <Color>Red</Color>
                                  </Style>
                                </TextRun>
